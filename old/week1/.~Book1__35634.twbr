      <column caption='Country' datatype='string' name='[COUNTRY]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Customername' datatype='string' hidden='true' name='[CUSTOMERNAME]' role='dimension' type='nominal' />
      <column caption='sales per unit' datatype='real' name='[Calculation_2507519848327454721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[SALES]/[QUANTITYORDERED]' />
      </column>
      <column caption='NewState' datatype='string' name='[Calculation_3130775810556317700]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([STATE]) THEN &#10;    &apos;No state&apos;&#10;ELSE &#10;    [STATE]&#10;END' />
      </column>
      <column caption='DealSizeEnc' datatype='integer' name='[Calculation_3130775810556940293]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [DEALSIZE] = &apos;Small&apos; Then&#10;    1&#10;ELSEIF [DEALSIZE] = &apos;Medium&apos; Then       &#10;    2&#10;ELSE&#10;    3&#10;End' />
      </column>
      <column caption='Price_mur' datatype='real' hidden='true' name='[Calculation_3130775810557587462]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[PRICEEACH] * 50' />
      </column>
      <column caption='Calculation1' datatype='integer' hidden='true' name='[Calculation_3130775810557726727]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([PRICEEACH])' />
      </column>
      <column aggregation='CountD' caption='UniniqueId' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_3130775810560974856]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([ORDERNUMBER])+STR([PRODUCTCODE])' />
      </column>
      <column caption='Dealsize' datatype='string' name='[DEALSIZE]' role='dimension' type='nominal' />
